<UserControl
    x:Class="Wintix.Controls.RecommendedActionCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Wintix.Converters">

    <UserControl.Resources>
        <converters:HexToBrushConverter x:Key="HexToBrushConverter" />
    </UserControl.Resources>

    <Border Style="{StaticResource WintixDashboardCardStyle}">
        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Border
                    Width="36"
                    Height="36"
                    Background="#141822"
                    BorderBrush="{StaticResource WintixBorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="9">
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                        FontSize="15"
                        Foreground="{x:Bind AccentColorHex, Mode=OneWay, Converter={StaticResource HexToBrushConverter}}"
                        Glyph="{x:Bind IconGlyph, Mode=OneWay}" />
                </Border>
                <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Text="{x:Bind Title, Mode=OneWay}" />
            </StackPanel>

            <TextBlock
                Grid.Row="1"
                FontSize="12"
                LineHeight="17"
                Foreground="{StaticResource WintixTextSecondaryBrush}"
                Text="{x:Bind Description, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />

            <TextBlock
                Grid.Row="2"
                FontSize="22"
                FontWeight="SemiBold"
                Foreground="{x:Bind AccentColorHex, Mode=OneWay, Converter={StaticResource HexToBrushConverter}}"
                Text="{x:Bind Value, Mode=OneWay}" />

            <Button
                Grid.Row="3"
                HorizontalAlignment="Left"
                Click="ActionButton_Click"
                Content="{x:Bind ActionText, Mode=OneWay}"
                Style="{StaticResource WintixGhostButtonStyle}" />
        </Grid>
    </Border>
</UserControl>
