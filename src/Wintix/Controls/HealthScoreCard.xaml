<UserControl
    x:Class="Wintix.Controls.HealthScoreCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource WintixDashboardHeroCardStyle}">
        <Grid RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Style="{StaticResource WintixLabelStyle}" Text="{x:Bind Label, Mode=OneWay}" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Bottom">
                <TextBlock
                    FontSize="48"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource WintixTextPrimaryBrush}"
                    LineHeight="56"
                    Text="{x:Bind Score, Mode=OneWay}" />
                <TextBlock
                    Margin="0,0,0,10"
                    VerticalAlignment="Bottom"
                    FontSize="18"
                    Foreground="{StaticResource WintixTextMutedBrush}"
                    Text="/100" />
            </StackPanel>

            <Border
                Grid.Row="2"
                Padding="8,4"
                HorizontalAlignment="Left"
                Background="#1410B981"
                BorderBrush="{StaticResource WintixSuccessBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource WintixSuccessBrush}" Text="{x:Bind StatusText, Mode=OneWay}" />
            </Border>

            <StackPanel Grid.Row="3" Spacing="8">
                <ProgressBar
                    x:Name="ScoreProgress"
                    Maximum="100"
                    Height="6"
                    Background="#1E293B"
                    BorderThickness="0"
                    Foreground="{StaticResource WintixAccentBrush}" />
                <TextBlock
                    MaxWidth="320"
                    FontSize="13"
                    LineHeight="18"
                    Foreground="{StaticResource WintixTextSecondaryBrush}"
                    Text="{x:Bind Summary, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
