<UserControl
    x:Class="Wintix.Controls.SidebarNavItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Margin="0,3">
        <Border
            x:Name="GlowLayer"
            Margin="-2"
            Background="{StaticResource WintixAccentGlowBrush}"
            CornerRadius="12"
            Opacity="0" />
        <Border
            x:Name="ActiveBorder"
            Background="#1800D4FF"
            BorderBrush="{StaticResource WintixAccentBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Opacity="0" />
        <Grid
            x:Name="ContentGrid"
            Padding="12,10"
            Background="Transparent"
            CornerRadius="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <FontIcon
                x:Name="NavIcon"
                Grid.Column="0"
                Margin="0,0,10,0"
                Width="18"
                HorizontalAlignment="Center"
                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                FontSize="16"
                Foreground="{StaticResource WintixTextSecondaryBrush}"
                Glyph="{x:Bind IconGlyph, Mode=OneWay}" />
            <TextBlock
                x:Name="NavLabel"
                Grid.Column="1"
                VerticalAlignment="Center"
                FontFamily="{StaticResource WintixFontFamily}"
                FontSize="13.5"
                Foreground="{StaticResource WintixTextSecondaryBrush}"
                Text="{x:Bind Label, Mode=OneWay}" />
        </Grid>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="SelectionStates">
                <VisualState x:Name="Inactive">
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="GlowLayer" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
                        <DoubleAnimation Storyboard.TargetName="ActiveBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="Active">
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="GlowLayer" Storyboard.TargetProperty="Opacity" To="0.22" Duration="0:0:0.18" />
                        <DoubleAnimation Storyboard.TargetName="ActiveBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
            <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentGrid" Storyboard.TargetProperty="Background">
                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource WintixSurfaceHoverBrush}" />
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="Pressed" />
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>
