<UserControl
    x:Class="Wintix.Controls.CompactMetricCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Wintix.Controls"
    xmlns:converters="using:Wintix.Converters">

    <UserControl.Resources>
        <converters:HexToBrushConverter x:Key="HexToBrushConverter" />
    </UserControl.Resources>

    <Border Style="{StaticResource WintixDashboardCardStyle}">
        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Width="32"
                    Height="32"
                    Background="#141822"
                    BorderBrush="{StaticResource WintixBorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                        FontSize="14"
                        Foreground="{x:Bind AccentColorHex, Mode=OneWay, Converter={StaticResource HexToBrushConverter}}"
                        Glyph="{x:Bind IconGlyph, Mode=OneWay}" />
                </Border>
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource WintixTextSecondaryBrush}"
                    Text="{x:Bind MetricName, Mode=OneWay}" />
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="2">
                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource WintixTextPrimaryBrush}"
                    Text="{x:Bind Value, Mode=OneWay}" />
                <TextBlock
                    Margin="0,10,0,0"
                    FontSize="14"
                    Foreground="{StaticResource WintixTextMutedBrush}"
                    Text="{x:Bind Unit, Mode=OneWay}" />
            </StackPanel>

            <TextBlock
                Grid.Row="2"
                FontSize="12"
                Foreground="{StaticResource WintixTextMutedBrush}"
                Text="{x:Bind Description, Mode=OneWay}" />

            <StackPanel Grid.Row="3" Spacing="8">
                <ProgressBar
                    Maximum="100"
                    Value="{x:Bind Percentage, Mode=OneWay}"
                    Height="4"
                    Background="#1E293B"
                    BorderThickness="0"
                    Foreground="{x:Bind AccentColorHex, Mode=OneWay, Converter={StaticResource HexToBrushConverter}}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        FontSize="11"
                        Foreground="{StaticResource WintixTextMutedBrush}"
                        Text="{x:Bind DetailText, Mode=OneWay}" />
                    <controls:SparklineChart
                        Grid.Column="1"
                        Width="72"
                        AccentColorHex="{x:Bind AccentColorHex, Mode=OneWay}"
                        Values="{x:Bind Sparkline, Mode=OneWay}" />
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
