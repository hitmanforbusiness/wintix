<UserControl
    x:Class="Wintix.Controls.ComponentDetailCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Wintix.Converters">

    <UserControl.Resources>
        <converters:HexToBrushConverter x:Key="HexToBrushConverter" />
    </UserControl.Resources>

    <Border Style="{StaticResource WintixDashboardCardStyle}">
        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                    Width="34"
                    Height="34"
                    Background="#141822"
                    BorderBrush="{StaticResource WintixBorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                        FontSize="14"
                        Foreground="{StaticResource WintixAccentBrush}"
                        Glyph="{x:Bind IconGlyph, Mode=OneWay}" />
                </Border>
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource WintixTextMutedBrush}"
                    Text="{x:Bind Category, Mode=OneWay}" />
                <Border
                    x:Name="StatusBadge"
                    Grid.Column="2"
                    Padding="8,3"
                    Background="#101822"
                    BorderBrush="{x:Bind StatusColorHex, Mode=OneWay, Converter={StaticResource HexToBrushConverter}}"
                    BorderThickness="1"
                    CornerRadius="5">
                    <TextBlock
                        x:Name="StatusTextBlock"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{x:Bind StatusColorHex, Mode=OneWay, Converter={StaticResource HexToBrushConverter}}"
                        Text="{x:Bind StatusText, Mode=OneWay}" />
                </Border>
            </Grid>

            <TextBlock
                Grid.Row="1"
                FontSize="15"
                FontWeight="SemiBold"
                Text="{x:Bind Title, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />

            <TextBlock
                Grid.Row="2"
                FontSize="12"
                Foreground="{StaticResource WintixTextSecondaryBrush}"
                Text="{x:Bind Detail, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />

            <Border Grid.Row="3" Height="1" Background="{StaticResource WintixBorderSubtleBrush}" />

            <TextBlock
                Grid.Row="4"
                FontFamily="{StaticResource WintixMonoFontFamily}"
                FontSize="11"
                Foreground="{StaticResource WintixTextMutedBrush}"
                Text="{x:Bind SpecLine, Mode=OneWay}" />
        </Grid>
    </Border>
</UserControl>
