<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="WintixFontSizeHero">32</x:Double>
    <x:Double x:Key="WintixFontSizeTitle">24</x:Double>
    <x:Double x:Key="WintixFontSizeHeading">18</x:Double>
    <x:Double x:Key="WintixFontSizeBody">14</x:Double>
    <x:Double x:Key="WintixFontSizeCaption">12</x:Double>
    <x:Double x:Key="WintixFontSizeMetric">36</x:Double>
    <x:Double x:Key="WintixFontSizeMetricLarge">48</x:Double>

    <FontFamily x:Key="WintixFontFamily">Segoe UI Variable Display, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="WintixMonoFontFamily">Cascadia Mono, Consolas, monospace</FontFamily>

    <Style x:Key="WintixHeroTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource WintixFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource WintixFontSizeHero}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource WintixTextPrimaryBrush}" />
        <Setter Property="LineHeight" Value="40" />
    </Style>

    <Style x:Key="WintixPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource WintixFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource WintixFontSizeTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource WintixTextPrimaryBrush}" />
    </Style>

    <Style x:Key="WintixSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource WintixFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource WintixFontSizeHeading}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource WintixTextPrimaryBrush}" />
    </Style>

    <Style x:Key="WintixSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource WintixFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource WintixFontSizeBody}" />
        <Setter Property="Foreground" Value="{StaticResource WintixTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <Style x:Key="WintixCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource WintixFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource WintixFontSizeCaption}" />
        <Setter Property="Foreground" Value="{StaticResource WintixTextMutedBrush}" />
        <Setter Property="CharacterSpacing" Value="40" />
    </Style>

    <Style x:Key="WintixMetricValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource WintixFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource WintixFontSizeMetric}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource WintixTextPrimaryBrush}" />
    </Style>

    <Style x:Key="WintixMetricLargeStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource WintixFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource WintixFontSizeMetricLarge}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource WintixTextPrimaryBrush}" />
    </Style>

    <Style x:Key="WintixLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource WintixFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource WintixFontSizeCaption}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource WintixTextSecondaryBrush}" />
        <Setter Property="CharacterSpacing" Value="60" />
    </Style>

    <Style x:Key="WintixCardValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource WintixFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource WintixTextPrimaryBrush}" />
    </Style>
</ResourceDictionary>
