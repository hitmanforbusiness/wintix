<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="WintixCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource WintixSurfaceElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WintixBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="22" />
    </Style>

    <Style x:Key="WintixPremiumCardStyle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#171F2E" Offset="0" />
                    <GradientStop Color="#121A28" Offset="0.55" />
                    <GradientStop Color="#0F1623" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource WintixBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="26" />
    </Style>

    <Style x:Key="WintixGlassCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#CC111827" />
        <Setter Property="BorderBrush" Value="#334155" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="WintixUsagePanelStyle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#162033" Offset="0" />
                    <GradientStop Color="#121A28" Offset="0.45" />
                    <GradientStop Color="#0E1520" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#35506E" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="28" />
    </Style>

    <Style x:Key="WintixListRowCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#121A28" />
        <Setter Property="BorderBrush" Value="{StaticResource WintixBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="WintixHeroPanelStyle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.8">
                    <GradientStop Color="#1A2840" Offset="0" />
                    <GradientStop Color="#121A28" Offset="0.55" />
                    <GradientStop Color="#0B1018" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#3B82F6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Padding" Value="28" />
    </Style>

    <Style x:Key="WintixDashboardCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#121A28" />
        <Setter Property="BorderBrush" Value="{StaticResource WintixBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="WintixDashboardHeroCardStyle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#152032" Offset="0" />
                    <GradientStop Color="#111827" Offset="0.6" />
                    <GradientStop Color="#0E1520" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#334155" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <Style x:Key="WintixUsageDetailPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="#101722" />
        <Setter Property="BorderBrush" Value="{StaticResource WintixBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="18" />
    </Style>
</ResourceDictionary>
