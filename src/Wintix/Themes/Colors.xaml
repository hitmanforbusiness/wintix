<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background layers -->
    <Color x:Key="WintixBackgroundColor">#070B12</Color>
    <Color x:Key="WintixSurfaceColor">#0F1623</Color>
    <Color x:Key="WintixSurfaceElevatedColor">#151E2E</Color>
    <Color x:Key="WintixSurfaceHoverColor">#1A2538</Color>
    <Color x:Key="WintixSidebarColor">#0A1019</Color>
    <Color x:Key="WintixBorderColor">#243044</Color>
    <Color x:Key="WintixBorderSubtleColor">#1A2333</Color>

    <!-- Accent -->
    <Color x:Key="WintixAccentColor">#00D4FF</Color>
    <Color x:Key="WintixAccentSecondaryColor">#3B82F6</Color>
    <Color x:Key="WintixAccentGlowColor">#3300D4FF</Color>
    <Color x:Key="WintixAccentMutedColor">#1A3A4A</Color>

    <!-- Semantic -->
    <Color x:Key="WintixSuccessColor">#10B981</Color>
    <Color x:Key="WintixWarningColor">#F59E0B</Color>
    <Color x:Key="WintixErrorColor">#EF4444</Color>
    <Color x:Key="WintixCpuColor">#22D3EE</Color>
    <Color x:Key="WintixRamColor">#A78BFA</Color>
    <Color x:Key="WintixDiskColor">#FBBF24</Color>
    <Color x:Key="WintixNetworkColor">#34D399</Color>

    <!-- Text -->
    <Color x:Key="WintixTextPrimaryColor">#F1F5F9</Color>
    <Color x:Key="WintixTextSecondaryColor">#94A3B8</Color>
    <Color x:Key="WintixTextMutedColor">#64748B</Color>

    <SolidColorBrush x:Key="WintixBackgroundBrush" Color="{StaticResource WintixBackgroundColor}" />
    <SolidColorBrush x:Key="WintixSurfaceBrush" Color="{StaticResource WintixSurfaceColor}" />
    <SolidColorBrush x:Key="WintixSurfaceElevatedBrush" Color="{StaticResource WintixSurfaceElevatedColor}" />
    <SolidColorBrush x:Key="WintixSurfaceHoverBrush" Color="{StaticResource WintixSurfaceHoverColor}" />
    <SolidColorBrush x:Key="WintixSidebarBrush" Color="{StaticResource WintixSidebarColor}" />
    <SolidColorBrush x:Key="WintixBorderBrush" Color="{StaticResource WintixBorderColor}" />
    <SolidColorBrush x:Key="WintixBorderSubtleBrush" Color="{StaticResource WintixBorderSubtleColor}" />
    <SolidColorBrush x:Key="WintixAccentBrush" Color="{StaticResource WintixAccentColor}" />
    <SolidColorBrush x:Key="WintixAccentSecondaryBrush" Color="{StaticResource WintixAccentSecondaryColor}" />
    <SolidColorBrush x:Key="WintixAccentGlowBrush" Color="{StaticResource WintixAccentGlowColor}" />
    <SolidColorBrush x:Key="WintixAccentMutedBrush" Color="{StaticResource WintixAccentMutedColor}" />
    <SolidColorBrush x:Key="WintixSuccessBrush" Color="{StaticResource WintixSuccessColor}" />
    <SolidColorBrush x:Key="WintixWarningBrush" Color="{StaticResource WintixWarningColor}" />
    <SolidColorBrush x:Key="WintixErrorBrush" Color="{StaticResource WintixErrorColor}" />
    <SolidColorBrush x:Key="WintixCpuBrush" Color="{StaticResource WintixCpuColor}" />
    <SolidColorBrush x:Key="WintixRamBrush" Color="{StaticResource WintixRamColor}" />
    <SolidColorBrush x:Key="WintixDiskBrush" Color="{StaticResource WintixDiskColor}" />
    <SolidColorBrush x:Key="WintixNetworkBrush" Color="{StaticResource WintixNetworkColor}" />
    <SolidColorBrush x:Key="WintixTextPrimaryBrush" Color="{StaticResource WintixTextPrimaryColor}" />
    <SolidColorBrush x:Key="WintixTextSecondaryBrush" Color="{StaticResource WintixTextSecondaryColor}" />
    <SolidColorBrush x:Key="WintixTextMutedBrush" Color="{StaticResource WintixTextMutedColor}" />

    <LinearGradientBrush x:Key="WintixAccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00D4FF" Offset="0" />
        <GradientStop Color="#3B82F6" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WintixSidebarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0C121C" Offset="0" />
        <GradientStop Color="#070B12" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WintixCardGlowGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1800D4FF" Offset="0" />
        <GradientStop Color="#00000000" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
