<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="WintixNavItemStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource WintixTextSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="14,11" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="FontFamily" Value="{StaticResource WintixFontFamily}" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
    </Style>

    <Style x:Key="WintixTopBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource WintixSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WintixBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="28,0" />
        <Setter Property="Height" Value="56" />
    </Style>
</ResourceDictionary>
