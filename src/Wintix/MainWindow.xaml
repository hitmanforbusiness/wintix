<Window
    x:Class="Wintix.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Wintix.Controls"
    xmlns:models="using:Wintix.Models"
    Title="Wintix">

    <Grid x:Name="RootGrid" Background="{StaticResource WintixBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource WintixSidebarGradientBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="18,22,18,16" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border
                        Width="46"
                        Height="46"
                        Background="{StaticResource WintixAccentGradientBrush}"
                        BorderBrush="#55FFFFFF"
                        BorderThickness="1"
                        CornerRadius="14">
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            FontSize="20"
                            Foreground="#061018"
                            Glyph="&#xE7F4;" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock
                            FontFamily="{StaticResource WintixFontFamily}"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{StaticResource WintixTextPrimaryBrush}"
                            Text="Wintix" />
                        <TextBlock Style="{StaticResource WintixCaptionStyle}" Text="{x:Bind ViewModel.AppTagline, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
                <Border Height="1" Background="{StaticResource WintixBorderSubtleBrush}" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsRepeater
                    x:Name="NavRepeater"
                    Margin="12,0,12,0"
                    ItemsSource="{x:Bind ViewModel.NavigationItems, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:NavigationItem">
                            <controls:SidebarNavItem
                                IconGlyph="{x:Bind IconGlyph}"
                                Label="{x:Bind Label}"
                                NavigationKey="{x:Bind Key}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Margin="18,12,18,22" Spacing="10">
                <Border Height="1" Background="{StaticResource WintixBorderSubtleBrush}" />
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource WintixCaptionStyle}" Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource WintixSubtitleStyle}" FontSize="12" Text="{x:Bind ViewModel.AppFooter, Mode=OneWay}" />
                </StackPanel>
                <Button
                    Click="SettingsShortcut_Click"
                    Content="{x:Bind ViewModel.SettingsShortcutText, Mode=OneWay}"
                    Style="{StaticResource WintixGhostButtonStyle}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="TopBar" Grid.Row="0" Style="{StaticResource WintixTopBarStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock FontSize="18" Style="{StaticResource WintixPageTitleStyle}" Text="{x:Bind ViewModel.TopBarTitle, Mode=OneWay}" />
                        <TextBlock Style="{StaticResource WintixCaptionStyle}" Text="{x:Bind ViewModel.TopBarSubtitle, Mode=OneWay}" />
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Background="#101822"
                        BorderBrush="{StaticResource WintixBorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource WintixSuccessBrush}" />
                            <TextBlock
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource WintixTextSecondaryBrush}"
                                Text="{x:Bind ViewModel.SystemReadyText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Frame x:Name="ContentFrame" Grid.Row="1" Background="{StaticResource WintixBackgroundBrush}" />
        </Grid>
    </Grid>
</Window>
