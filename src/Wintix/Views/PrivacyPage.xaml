<Page
    x:Class="Wintix.Views.PrivacyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Wintix.Controls"
    xmlns:models="using:Wintix.Models"
    Background="{StaticResource WintixBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="28,24,28,32" Spacing="22">
            <controls:SectionHeader
                x:Name="PageHeader"
                ActionText="{x:Bind ViewModel.RefreshActionText, Mode=OneWay}"
                ShowAction="True"
                Subtitle="{x:Bind ViewModel.PageSubtitle, Mode=OneWay}"
                Title="{x:Bind ViewModel.PageTitle, Mode=OneWay}" />

            <Border Style="{StaticResource WintixPremiumCardStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Command="{x:Bind ViewModel.OpenPrivacySettingsCommand}" Content="{x:Bind ViewModel.OpenSettingsText, Mode=OneWay}" Style="{StaticResource WintixPrimaryButtonStyle}" />
                        <Button Command="{x:Bind ViewModel.CleanTempDataCommand}" Content="{x:Bind ViewModel.CleanTempText, Mode=OneWay}" Style="{StaticResource WintixGhostButtonStyle}" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource WintixSubtitleStyle}" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource WintixSectionTitleStyle}" Text="{x:Bind ViewModel.OverviewTitle, Mode=OneWay}" />

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Actions, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinColumnSpacing="14" MinItemWidth="320" MinRowSpacing="14" Orientation="Horizontal" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:PrivacyActionItem">
                        <Border Style="{StaticResource WintixPremiumCardStyle}">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border
                                        Width="40"
                                        Height="40"
                                        Background="{StaticResource WintixAccentMutedBrush}"
                                        BorderBrush="{StaticResource WintixAccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                            Foreground="{StaticResource WintixAccentBrush}"
                                            Glyph="{x:Bind IconGlyph}" />
                                    </Border>
                                    <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="{x:Bind Title}" />
                                </StackPanel>
                                <TextBlock Style="{StaticResource WintixSubtitleStyle}" FontSize="13" Text="{x:Bind Description}" />
                                <Border
                                    Padding="8,4"
                                    HorizontalAlignment="Left"
                                    Background="#1522C55E"
                                    BorderBrush="{StaticResource WintixSuccessBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <TextBlock Foreground="{StaticResource WintixSuccessBrush}" FontSize="12" Text="{x:Bind Status}" />
                                </Border>
                                <Button
                                    HorizontalAlignment="Left"
                                    Click="ActionButton_Click"
                                    Content="{x:Bind ManageLabel, Mode=OneWay}"
                                    Style="{StaticResource WintixGhostButtonStyle}"
                                    Tag="{x:Bind}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </ScrollViewer>
</Page>
