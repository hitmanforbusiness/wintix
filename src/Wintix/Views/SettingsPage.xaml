<Page
    x:Class="Wintix.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Wintix.Models"
    Background="{StaticResource WintixBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="28,24,28,32" MaxWidth="760" Spacing="22">
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource WintixPageTitleStyle}" Text="{x:Bind ViewModel.PageTitle, Mode=OneWay}" />
                <TextBlock Style="{StaticResource WintixSubtitleStyle}" Text="{x:Bind ViewModel.PageSubtitle, Mode=OneWay}" />
            </StackPanel>

            <Border Style="{StaticResource WintixPremiumCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource WintixSectionTitleStyle}" Text="{x:Bind ViewModel.LanguageSectionTitle, Mode=OneWay}" />
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        Header="{x:Bind ViewModel.LanguageHeader, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.LanguageOptions, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedLanguageOption, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:LanguageOption">
                                <TextBlock Text="{x:Bind Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource WintixPremiumCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource WintixSectionTitleStyle}" Text="{x:Bind ViewModel.AppearanceTitle, Mode=OneWay}" />
                    <ToggleSwitch Header="{x:Bind ViewModel.DarkThemeHeader, Mode=OneWay}" IsOn="{x:Bind ViewModel.UseDarkTheme, Mode=TwoWay}" />
                    <ToggleSwitch Header="{x:Bind ViewModel.AccentGlowHeader, Mode=OneWay}" IsOn="{x:Bind ViewModel.AccentGlowEffects, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource WintixPremiumCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource WintixSectionTitleStyle}" Text="{x:Bind ViewModel.NotificationsTitle, Mode=OneWay}" />
                    <ToggleSwitch Header="{x:Bind ViewModel.HealthAlertsHeader, Mode=OneWay}" IsOn="{x:Bind ViewModel.SystemHealthAlerts, Mode=TwoWay}" />
                    <ToggleSwitch Header="{x:Bind ViewModel.ScanRemindersHeader, Mode=OneWay}" IsOn="{x:Bind ViewModel.ScheduledScanReminders, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource WintixPremiumCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource WintixSectionTitleStyle}" Text="{x:Bind ViewModel.StartupSectionTitle, Mode=OneWay}" />
                    <ToggleSwitch Header="{x:Bind ViewModel.LaunchAtStartupHeader, Mode=OneWay}" IsOn="{x:Bind ViewModel.LaunchAtStartup, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Command="{x:Bind ViewModel.SaveCommand}" Content="{x:Bind ViewModel.SaveButtonText, Mode=OneWay}" Style="{StaticResource WintixPrimaryButtonStyle}" />
                <Button Command="{x:Bind ViewModel.LoadFromServiceCommand}" Content="{x:Bind ViewModel.ResetButtonText, Mode=OneWay}" Style="{StaticResource WintixGhostButtonStyle}" />
            </StackPanel>

            <TextBlock Style="{StaticResource WintixSubtitleStyle}" Foreground="{StaticResource WintixSuccessBrush}" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />

            <Border Style="{StaticResource WintixHeroPanelStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource WintixSectionTitleStyle}" Text="{x:Bind ViewModel.AboutTitle, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource WintixSubtitleStyle}" Text="{x:Bind ViewModel.AboutText, Mode=OneWay}" />
                    <TextBlock FontFamily="{StaticResource WintixMonoFontFamily}" Foreground="{StaticResource WintixTextMutedBrush}" Text="{x:Bind ViewModel.AboutVersion, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
