<Page
    x:Class="Wintix.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16" MaxWidth="640">
            <TextBlock Style="{StaticResource PageTitleStyle}" Text="Settings" />
            <TextBlock
                Style="{StaticResource SectionSubtitleStyle}"
                Text="Configure Wintix preferences. More options will arrive in upcoming releases." />

            <ToggleSwitch Header="Use system theme" IsOn="True" OffContent="Custom" OnContent="System" />
            <ToggleSwitch Header="Show ticket notifications" IsOn="True" />

            <TextBlock Margin="0,16,0,0" Opacity="0.7">
                <Run Text="Version " />
                <Run Text="0.1.0" />
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</Page>
