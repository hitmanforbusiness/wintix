<Page
    x:Class="Wintix.Views.TicketsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Wintix.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource PageTitleStyle}" Text="My Tickets" />
        <TextBlock
            Grid.Row="1"
            Style="{StaticResource SectionSubtitleStyle}"
            Text="Your purchased tickets and check-in codes in one place." />

        <ProgressRing
            Grid.Row="2"
            HorizontalAlignment="Left"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.Tickets, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:TicketItem">
                    <Border
                        Margin="0,0,0,8"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind EventTitle}" />
                            <TextBlock Opacity="0.8" Text="{x:Bind Venue}" />
                            <TextBlock Text="{x:Bind FormattedDate}" />
                            <TextBlock Text="{x:Bind Seat}" />
                            <TextBlock FontFamily="Consolas" Text="{x:Bind Barcode}" />
                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Status}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
