<Page
    x:Class="Wintix.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Wintix.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="12">
            <TextBlock Style="{StaticResource PageTitleStyle}" Text="Welcome to Wintix" />
            <TextBlock
                Style="{StaticResource SectionSubtitleStyle}"
                Text="Discover events, manage tickets, and check in — all from a native Windows experience." />

            <ProgressRing
                HorizontalAlignment="Left"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

            <TextBlock
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Featured events" />

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.FeaturedEvents, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        MinColumnSpacing="12"
                        MinItemWidth="280"
                        MinRowSpacing="12"
                        Orientation="Horizontal" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:EventItem">
                        <Border
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="6">
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind Title}" />
                                <TextBlock Opacity="0.8" Text="{x:Bind Venue}" />
                                <TextBlock Opacity="0.8" Text="{x:Bind Category}" />
                                <TextBlock Text="{x:Bind FormattedDate}" />
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind FormattedPrice}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </ScrollViewer>
</Page>
