<Page
    x:Class="Wintix.Views.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Wintix.Controls"
    xmlns:models="using:Wintix.Models"
    Background="{StaticResource WintixBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="28,24,28,32" Spacing="22">
            <controls:SectionHeader
                x:Name="PageHeader"
                ActionText="{x:Bind ViewModel.RefreshActionText, Mode=OneWay}"
                ShowAction="True"
                Subtitle="{x:Bind ViewModel.PageSubtitle, Mode=OneWay}"
                Title="{x:Bind ViewModel.PageTitle, Mode=OneWay}" />

            <Border Style="{StaticResource WintixHeroPanelStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource WintixSectionTitleStyle}" Text="{x:Bind ViewModel.PingTestTitle, Mode=OneWay}" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox PlaceholderText="{x:Bind ViewModel.HostPlaceholder, Mode=OneWay}" Text="{x:Bind ViewModel.PingHost, Mode=TwoWay}" />
                        <Button
                            Grid.Column="1"
                            Command="{x:Bind ViewModel.PingCommand}"
                            Content="{x:Bind ViewModel.PingButtonText, Mode=OneWay}"
                            Style="{StaticResource WintixPrimaryButtonStyle}" />
                    </Grid>
                    <Border
                        Padding="14"
                        Background="#121A28"
                        BorderBrush="{StaticResource WintixBorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                        <TextBlock
                            FontFamily="{StaticResource WintixMonoFontFamily}"
                            Style="{StaticResource WintixSubtitleStyle}"
                            Text="{x:Bind ViewModel.PingResult, Mode=OneWay}" />
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Command="{x:Bind ViewModel.FlushDnsCommand}" Content="{x:Bind ViewModel.FlushDnsText, Mode=OneWay}" Style="{StaticResource WintixGhostButtonStyle}" />
                        <Button Command="{x:Bind ViewModel.OpenSettingsCommand}" Content="{x:Bind ViewModel.OpenSettingsText, Mode=OneWay}" Style="{StaticResource WintixGhostButtonStyle}" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource WintixSubtitleStyle}" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource WintixSectionTitleStyle}" Text="{x:Bind ViewModel.AdaptersTitle, Mode=OneWay}" />

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Adapters, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinColumnSpacing="14" MinItemWidth="280" MinRowSpacing="14" Orientation="Horizontal" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:NetworkAdapterItem">
                        <controls:InfoCard Category="{x:Bind Type}" Detail="{x:Bind Ipv4}" IconGlyph="&#xE701;" Title="{x:Bind Name}" />
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </ScrollViewer>
</Page>
