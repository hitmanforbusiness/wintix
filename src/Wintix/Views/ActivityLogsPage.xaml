<Page
    x:Class="Wintix.Views.ActivityLogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Wintix.Controls"
    xmlns:models="using:Wintix.Models"
    Background="{StaticResource WintixBackgroundBrush}">

    <Grid Padding="28,24,28,32" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:SectionHeader
            x:Name="PageHeader"
            Grid.Row="0"
            ActionText="{x:Bind ViewModel.ClearActionText, Mode=OneWay}"
            ShowAction="True"
            Subtitle="{x:Bind ViewModel.PageSubtitle, Mode=OneWay}"
            Title="{x:Bind ViewModel.PageTitle, Mode=OneWay}" />

        <Border Grid.Row="1" Style="{StaticResource WintixGlassCardStyle}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox PlaceholderText="{x:Bind ViewModel.FilterPlaceholder, Mode=OneWay}" Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Command="{x:Bind ViewModel.RefreshCommand}" Content="{x:Bind ViewModel.RefreshText, Mode=OneWay}" Style="{StaticResource WintixGhostButtonStyle}" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="2" Style="{StaticResource WintixSubtitleStyle}" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <TextBlock Style="{StaticResource WintixSectionTitleStyle}" Text="{x:Bind ViewModel.EntriesTitle, Mode=OneWay}" />
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.FilteredEntries, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:ActivityLogEntry">
                            <Border Style="{StaticResource WintixListRowCardStyle}">
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        FontFamily="{StaticResource WintixMonoFontFamily}"
                                        Foreground="{StaticResource WintixTextMutedBrush}"
                                        Text="{x:Bind FormattedTime}" />
                                    <Border
                                        Grid.Column="1"
                                        Padding="8,4"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource WintixAccentMutedBrush}"
                                        BorderBrush="{StaticResource WintixAccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource WintixAccentBrush}" Text="{x:Bind Category}" />
                                    </Border>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" TextWrapping="WrapWholeWords" Text="{x:Bind Message}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
